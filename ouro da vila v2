<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0">
<title>OURO da Vila — Pizzaria & Restaurante</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--gold:#D4A017;--gold2:#F0C040;--dark:#111;--dark2:#1a1a1a;--red:#C0392B;--red2:#E74C3C;--green:#25D366;--text:#f5f0e8;--muted:#c9b99a;--border:#2a2a2a}
html{scroll-behavior:smooth}
body{background:var(--dark);color:var(--text);font-family:'Segoe UI',Arial,sans-serif;font-size:15px;overflow-x:hidden}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:11px 22px;border-radius:8px;font-size:14px;font-weight:800;cursor:pointer;border:none;text-decoration:none;transition:filter .15s,transform .1s}
.btn:active{transform:scale(0.96)}
.btn-gold{background:var(--gold2);color:#000}.btn-gold:hover{filter:brightness(1.1)}
.btn-outline{background:transparent;color:var(--gold2);border:2px solid var(--gold2)}.btn-outline:hover{background:var(--gold2);color:#000}
.btn-green{background:var(--green);color:#fff}
.btn-red{background:var(--red2);color:#fff}
.btn-full{width:100%;padding:14px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.food-img{width:100%;height:130px;object-fit:cover;display:block;background:linear-gradient(90deg,#1a1a1a 25%,#252525 50%,#1a1a1a 75%);background-size:200% 100%;animation:shimmer 1.5s infinite}
.food-img.ok{animation:none}

/* URGENCY */
.urgency{background:var(--red2);text-align:center;padding:9px;font-size:13px;font-weight:700;color:#fff;letter-spacing:1px}

/* HEADER */
header{background:#0d0d0d;border-bottom:2px solid var(--gold);position:sticky;top:0;z-index:100;padding:8px 0}
.hinner{max-width:980px;margin:auto;padding:0 14px;display:flex;align-items:center;justify-content:space-between;gap:8px}
.logo-box{display:flex;align-items:center;gap:8px}
.logo-text .t1{font-size:17px;font-weight:900;color:var(--gold2);letter-spacing:2px;line-height:1}
.logo-text .t2{font-size:9px;color:var(--muted);letter-spacing:2px}
.hnav{display:flex;gap:6px}
.hnav a{color:var(--gold);font-size:12px;text-decoration:none;padding:5px 9px;border:1px solid var(--gold);border-radius:4px}
.hnav a:hover{background:var(--gold);color:#000}
@media(max-width:480px){.hnav{display:none}}

/* HERO */
.hero{position:relative;min-height:400px;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden;border-bottom:3px solid var(--gold)}
#hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.28)}
.hero-content{position:relative;z-index:1;padding:50px 16px}
.hero h1{font-size:clamp(1.7rem,5vw,3rem);font-weight:900;color:var(--gold2);text-shadow:0 2px 16px rgba(0,0,0,.9);margin-bottom:10px}
.hero p{font-size:1rem;color:#e0d8c8;max-width:500px;margin:0 auto 24px}
.hero-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
.hero-addr{margin-top:16px;font-size:11px;color:rgba(255,255,255,.5)}

/* PROMO */
.promo-wrap{padding:0 14px;max-width:780px;margin:22px auto}
.promo{background:var(--red2);border:3px solid var(--gold2);border-radius:12px;overflow:hidden;display:grid;grid-template-columns:1fr 160px}
.promo-body{padding:16px}
.ptag{font-size:10px;letter-spacing:2px;color:#fff0a0;text-transform:uppercase;margin-bottom:4px}
.promo-body h2{font-size:1.1rem;font-weight:900;color:#fff;margin-bottom:4px}
.promo-price{font-size:2rem;font-weight:900;color:var(--gold2);line-height:1}
.promo-body small{font-size:11px;color:#ffc;display:block;margin:4px 0 12px}
@media(max-width:500px){.promo{grid-template-columns:1fr}.promo-side{display:none}}

/* SECTIONS */
section.lsec{max-width:980px;margin:0 auto;padding:28px 14px}
.stitle{font-size:1rem;font-weight:800;color:var(--gold2);border-left:4px solid var(--gold);padding-left:10px;margin-bottom:14px;text-transform:uppercase;letter-spacing:1px}
.stag{font-size:11px;color:var(--muted);font-weight:400;letter-spacing:0;text-transform:none;margin-left:6px}

/* CARDS */
.mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px}
@media(min-width:600px){.mgrid{grid-template-columns:repeat(auto-fill,minmax(195px,1fr))}}
.card{background:var(--dark2);border:1px solid var(--border);border-radius:10px;overflow:hidden;display:flex;flex-direction:column;transition:border-color .2s,transform .2s}
.card:hover{border-color:var(--gold);transform:translateY(-2px)}
.card-body{padding:10px;display:flex;flex-direction:column;gap:5px;flex:1}
.cn{font-size:13px;font-weight:700;color:var(--text)}
.cd{font-size:11px;color:var(--muted);flex:1;line-height:1.4}
.cf{display:flex;align-items:center;justify-content:space-between;gap:4px;margin-top:4px}
.cp{font-size:13px;font-weight:800;color:var(--gold2)}
.abtn{background:var(--gold2);color:#000;border:none;border-radius:5px;padding:6px 12px;font-size:12px;font-weight:800;cursor:pointer;min-height:34px}
.abtn:hover{filter:brightness(1.1)}
.pcard{background:var(--dark2);border:1px solid var(--border);border-radius:10px;overflow:hidden;display:flex;flex-direction:column;transition:border-color .2s,transform .2s}
.pcard:hover{border-color:var(--gold);transform:translateY(-2px)}
.pcard-body{padding:10px;display:flex;flex-direction:column;gap:7px}
.pcard select{background:#111;color:var(--text);border:1px solid #3a3a3a;border-radius:5px;padding:7px 8px;font-size:13px;width:100%;min-height:38px}

/* CART */
#cpanel{position:fixed;top:0;right:0;height:100%;width:min(340px,100vw);background:#151515;border-left:2px solid var(--gold);z-index:300;transform:translateX(110%);transition:transform .25s;display:flex;flex-direction:column}
#cpanel.open{transform:translateX(0)}
.ch{background:#0d0d0d;padding:14px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border)}
.ch h3{font-size:1rem;font-weight:800;color:var(--gold2)}
#cclose{background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;padding:4px 8px;min-height:44px}
#citems{flex:1;overflow-y:auto;padding:12px 14px;display:flex;flex-direction:column;gap:8px}
.ci{display:flex;align-items:flex-start;gap:6px;font-size:13px}
.ci-n{flex:1;color:var(--text);line-height:1.3}
.ci-p{color:var(--gold2);white-space:nowrap;font-weight:700}
.ci-x{background:none;border:none;color:#666;cursor:pointer;font-size:16px;padding:0 4px;min-width:28px;min-height:28px}
.cupsell{background:#100a00;border:1px solid var(--gold);border-radius:6px;padding:10px;font-size:12px;color:var(--gold);margin:0 14px 8px}
.cfooter{padding:14px;border-top:1px solid var(--border)}
.ctotal{display:flex;justify-content:space-between;font-weight:800;font-size:1rem;color:var(--gold2);margin-bottom:10px}
#cbadge{position:absolute;top:-7px;right:-7px;background:var(--red2);color:#fff;border-radius:50%;font-size:10px;font-weight:800;width:20px;height:20px;display:none;align-items:center;justify-content:center}

/* CHECKOUT */
#chk{display:none;max-width:560px;margin:0 auto;padding:28px 14px}
.fg{margin-bottom:12px}
.fg label{display:block;font-size:11px;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:1px}
.fg input{width:100%;background:#111;color:var(--text);border:1px solid #3a3a3a;border-radius:6px;padding:10px 12px;font-size:15px;min-height:44px}
.rg{display:flex;gap:8px}
.ro{flex:1;padding:10px;border:1px solid #3a3a3a;border-radius:8px;text-align:center;cursor:pointer;font-size:13px;color:var(--muted);min-height:44px;display:flex;align-items:center;justify-content:center}
.ro.sel{border-color:var(--gold2);color:var(--gold2);background:#1a1000}
.payg{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.po{padding:10px 4px;border:1px solid #3a3a3a;border-radius:8px;text-align:center;cursor:pointer;font-size:12px;font-weight:700;background:#111;color:var(--muted);min-height:44px;display:flex;align-items:center;justify-content:center}
.po.sel{border-color:var(--gold2);color:var(--gold2);background:#1a1000}
#pixbox{background:#100a00;border:1px solid var(--gold);border-radius:8px;padding:14px;text-align:center;margin-top:10px;display:none}

/* EVENTS */
.ev-box{background:linear-gradient(135deg,#1a1000,#1a0a0a);border:2px solid var(--gold);border-radius:12px;overflow:hidden}
.ev-body{padding:22px;text-align:center}
.ev-tags{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin:12px 0 18px}
.ev-tag{background:rgba(212,160,23,.12);border:1px solid var(--gold);border-radius:20px;padding:5px 12px;font-size:12px;color:var(--gold2)}

/* REVIEWS */
.rvgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:10px}
.rv{background:var(--dark2);border:1px solid var(--border);border-radius:8px;padding:12px}
.stars{color:var(--gold2);font-size:13px;margin-bottom:5px}

/* FLOATS */
#wafloat{position:fixed;bottom:20px;right:16px;z-index:200;background:var(--green);color:#fff;border:none;border-radius:50px;padding:13px 18px;font-size:14px;font-weight:800;cursor:pointer;box-shadow:0 4px 16px rgba(37,211,102,.5);min-height:48px}
#cartfloat{position:fixed;bottom:20px;left:16px;z-index:200;background:var(--gold2);color:#000;border:none;border-radius:50px;padding:12px 16px;font-size:13px;font-weight:800;cursor:pointer;box-shadow:0 4px 16px rgba(212,160,0,.4);display:none;min-height:48px}

/* LOGIN */
#view-login{display:none;min-height:100vh;align-items:center;justify-content:center;background:var(--dark)}
.login-box{background:var(--dark2);border:1px solid var(--gold);border-radius:12px;padding:36px 28px;width:min(320px,90vw);text-align:center}
.login-box h2{font-size:1rem;color:var(--gold2);margin:14px 0 4px;font-weight:900}
.login-box p{font-size:12px;color:var(--muted);margin-bottom:20px}
.login-box input{width:100%;background:#111;color:var(--text);border:1px solid var(--border);border-radius:6px;padding:11px 14px;font-size:15px;margin-bottom:10px;min-height:44px}
.lerr{font-size:12px;color:var(--red2);margin-bottom:8px;display:none}
.back-link{display:block;margin-top:14px;font-size:12px;color:var(--muted);cursor:pointer;text-decoration:underline}

/* ADMIN */
#view-admin{display:none}
.adm-header{background:#0d0d0d;border-bottom:2px solid var(--gold);padding:10px 14px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.adm-tabs{display:flex;overflow-x:auto;border-bottom:2px solid var(--border);background:var(--dark2);-webkit-overflow-scrolling:touch}
.adm-tab{padding:12px 16px;font-size:13px;font-weight:700;color:var(--muted);cursor:pointer;white-space:nowrap;border:none;background:none;border-bottom:3px solid transparent;margin-bottom:-2px;min-height:44px}
.adm-tab.active{color:var(--gold2);border-bottom-color:var(--gold2)}
.adm-page{display:none;padding:16px 14px;max-width:980px;margin:0 auto}
.adm-page.active{display:block}
.stats{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:18px}
@media(min-width:600px){.stats{grid-template-columns:repeat(4,1fr)}}
.stat{background:var(--dark2);border:1px solid var(--border);border-radius:10px;padding:14px}
.stat-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
.stat-val{font-size:1.5rem;font-weight:900;color:var(--gold2);line-height:1}
.order-card{background:var(--dark2);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:10px}
.oc-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px}
.oc-id{font-size:13px;font-weight:800;color:var(--gold2)}
.oc-time{font-size:11px;color:var(--muted)}
.oc-name{font-size:14px;font-weight:700;margin-bottom:2px}
.oc-addr{font-size:11px;color:var(--muted)}
.oc-items{font-size:12px;color:var(--muted);margin:6px 0}
.oc-bottom{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:8px}
.oc-total{font-size:15px;font-weight:800;color:var(--gold2);flex:1}
.status-badge{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap}
.s-novo{background:#1a1000;color:#F0C040;border:1px solid var(--gold)}
.s-prep{background:#1a0a00;color:#E67E22;border:1px solid #E67E22}
.s-saiu{background:#0a1020;color:#3498db;border:1px solid #3498db}
.s-entregue{background:#0a1a0a;color:#2ecc71;border:1px solid #2ecc71}
.s-cancelado{background:#1a0a0a;color:#e74c3c;border:1px solid #e74c3c}
.oc-sel{background:#111;color:var(--text);border:1px solid var(--border);border-radius:6px;padding:6px 8px;font-size:12px;flex:1;min-height:36px}
.oc-btn{background:none;border:1px solid var(--border);color:var(--muted);border-radius:6px;padding:6px 10px;font-size:12px;cursor:pointer;min-height:36px}
.oc-btn.wa{border-color:var(--green);color:var(--green)}
.ma-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px}
.ma-card{background:var(--dark2);border:1px solid var(--border);border-radius:8px;padding:12px}
.ma-card.off{opacity:.45;border-style:dashed}
.ma-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px}
.ma-name{font-size:13px;font-weight:700}.ma-cat{font-size:10px;color:var(--muted);margin-top:2px}
.toggle{position:relative;width:42px;height:24px;flex-shrink:0}
.toggle input{opacity:0;width:0;height:0}
.tslider{position:absolute;inset:0;background:#333;border-radius:20px;cursor:pointer;transition:.3s}
.tslider:before{content:'';position:absolute;width:18px;height:18px;left:3px;top:3px;background:#666;border-radius:50%;transition:.3s}
.toggle input:checked+.tslider{background:var(--gold)}
.toggle input:checked+.tslider:before{transform:translateX(18px);background:#000}
.price-inp{background:#111;color:var(--gold2);border:1px solid var(--border);border-radius:5px;padding:5px 8px;font-size:14px;font-weight:800;width:100%;min-height:36px}
.filters{display:flex;overflow-x:auto;gap:8px;margin-bottom:14px;padding-bottom:4px;-webkit-overflow-scrolling:touch}
.filt{padding:7px 14px;border-radius:20px;border:1px solid var(--border);background:none;color:var(--muted);font-size:12px;cursor:pointer;white-space:nowrap;min-height:36px;flex-shrink:0}
.filt.active{border-color:var(--gold2);color:var(--gold2);background:#1a1000}
.chart-box{background:var(--dark2);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:14px}
.chart-box h4{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px}
.bar-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.bar-lbl{font-size:11px;color:var(--muted);width:90px;text-align:right;flex-shrink:0}
.bar-track{flex:1;background:#222;border-radius:4px;height:14px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;background:var(--gold2);transition:width .6s}
.bar-val{font-size:11px;color:var(--gold2);width:55px;flex-shrink:0}
#modal{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:500;display:none;align-items:flex-end;justify-content:center}
#modal.open{display:flex}
.modal-box{background:var(--dark2);border:2px solid var(--gold);border-radius:16px 16px 0 0;padding:20px 16px;width:100%;max-width:500px;max-height:85vh;overflow-y:auto}
.modal-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}
.modal-hdr h3{font-size:1rem;font-weight:800;color:var(--gold2)}
.modal-close{background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;padding:4px 8px;min-height:44px}
.mrow{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px}
.mrow:last-child{border:none}
.mlbl{color:var(--muted)}.mval{color:var(--text);font-weight:600;text-align:right;max-width:55%}
.mitems{background:#111;border-radius:8px;padding:10px;margin:10px 0}
.mitem{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:1px solid #222}
.mitem:last-child{border:none}
.mtotal{display:flex;justify-content:space-between;font-weight:800;color:var(--gold2);font-size:1rem;padding-top:8px;margin-top:4px}
#toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(30px);background:var(--dark2);border:1px solid var(--gold);border-radius:8px;padding:10px 18px;font-size:13px;color:var(--gold2);z-index:999;opacity:0;transition:all .3s;white-space:nowrap}
#toast.show{transform:translateX(-50%) translateY(0);opacity:1}
</style>
</head>
<body>
<div id="view-landing">

<div class="urgency">⚡ Pedidos sendo feitos agora em Vila Isabel — garanta o seu!</div>

<header>
  <div class="hinner">
    <div class="logo-box">
      <svg width="40" height="40" viewBox="0 0 52 52"><rect width="52" height="52" rx="4" fill="#C0392B" stroke="#F0C040" stroke-width="2.5"/><rect x="3" y="3" width="46" height="46" rx="3" fill="none" stroke="#F0C040" stroke-width="1"/><polygon points="26,7 28.5,14.5 36.5,14.5 30,19.5 32.5,27 26,22.5 19.5,27 22,19.5 15.5,14.5 23.5,14.5" fill="#F0C040"/><text x="26" y="36" text-anchor="middle" font-size="8" font-weight="900" fill="#F0C040" font-family="Arial" letter-spacing="1">OURO</text><text x="26" y="45" text-anchor="middle" font-size="6" font-weight="700" fill="#fff" font-family="Arial" letter-spacing="2">DA VILA</text></svg>
      <div class="logo-text"><div class="t1">OURO DA VILA</div><div class="t2">Pizzaria &amp; Restaurante</div></div>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <div class="hnav"><a href="#cardapio">Cardápio</a><a href="#eventos">Eventos</a><a href="#contato">Contato</a></div>
      <button class="btn btn-gold" onclick="openCart()" style="position:relative;padding:8px 12px;font-size:13px;min-height:40px">🛒<span id="cbadge" style="position:absolute;top:-7px;right:-7px;background:#E74C3C;color:#fff;border-radius:50%;font-size:10px;font-weight:800;width:20px;height:20px;display:none;align-items:center;justify-content:center">0</span></button>
    </div>
  </div>
</header>

<div class="hero">
  <img id="hero-bg" src="https://images.pexels.com/photos/1640777/pexels-photo-1640777.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.28)">
  <div class="hero-content">
    <h1>🍕 O sabor que conquista Vila Isabel</h1>
    <p>Pizzas, almoço, petiscos e mais — delivery ou retirada, rápido e gostoso</p>
    <div class="hero-btns">
      <a href="#cardapio" class="btn btn-gold">🛒 Pedir Agora</a>
      <a href="#cardapio" class="btn btn-outline">📋 Cardápio</a>
      <a href="https://wa.me/5521980354365" target="_blank" class="btn btn-green">💬 WhatsApp</a>
    </div>
    <p class="hero-addr">📍 Blvd 28 de Setembro, 72 - Vila Isabel · ☎ (21) 2577-7780</p>
  </div>
</div>

<div class="promo-wrap">
  <div class="promo">
    <div class="promo-body">
      <div class="ptag">🚨 Promoção — Delivery</div>
      <h2>2 Pizzas Família 35cm + Pepsi 1,5L</h2>
      <div class="promo-price">R$ 79,90</div>
      <small>Portuguesa · Marguerita · Calabresa · Mussarela · Frango c/ Catupiry</small>
      <button class="btn btn-gold" style="padding:9px 16px;font-size:13px" onclick="add('Combo 2 Pizzas + Pepsi 1,5L',79.90,'Combo')">🔥 Aproveitar</button>
    </div>
    <div class="promo-side" style="overflow:hidden">
      <img src="https://images.pexels.com/photos/905847/pexels-photo-905847.jpeg?auto=compress&cs=tinysrgb&w=400" style="width:100%;height:100%;object-fit:cover;min-height:150px" alt="Pizza">
    </div>
  </div>
</div>

<section class="lsec" id="cardapio">
  <div class="stitle">🍟 Petiscos <span class="stag">pra compartilhar</span></div>
  <div class="mgrid" id="g-pet"></div>

  <div class="stitle" style="margin-top:26px">🍲 Sopas <span class="stag">quentinhas</span></div>
  <div class="mgrid" id="g-sop"></div>

