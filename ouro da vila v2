/* CART */
let cart=[],cartOpen=false,ent='delivery',pay='pix';
function add(name,price,cat){cart.push({name,price,cat});updUI();if(!cartOpen)openCart()}
function rem(i){cart.splice(i,1);updUI()}
function updUI(){
  const el=document.getElementById('citems'),badge=document.getElementById('cbadge'),cf=document.getElementById('cartfloat');
  const total=cart.reduce((s,i)=>s+i.price,0),n=cart.length;
  document.getElementById('ctv').textContent=fmt(total);
  document.getElementById('chktotal').textContent=fmt(total);
  badge.textContent=n;badge.style.display=n?'flex':'none';
  document.getElementById('cf-n').textContent=n;cf.style.display=n?'flex':'none';
  if(!n){el.innerHTML='<p style="color:var(--muted);font-size:13px;text-align:center;margin-top:24px">Carrinho vazio.</p>';document.getElementById('upsell').style.display='none';return}
  el.innerHTML=cart.map((i,idx)=>`<div class="ci"><span class="ci-n">${i.name}</span><span class="ci-p">${fmt(i.price)}</span><button class="ci-x" onclick="rem(${idx})">✕</button></div>`).join('');
  const cats=cart.map(i=>i.cat),ub=document.getElementById('upsell');
  let msg='';
  if(cats.some(c=>c.includes('Pizza')||c==='Combo'))msg='🍟 Adicione batata frita ou cerveja!';
  else if(cats.some(c=>c==='Executivo'))msg='🥤 Complete com um suco natural!';
  else if(cats.some(c=>c==='Petiscos'))msg='🍺 Petiscos pedem cerveja gelada!';
  ub.textContent=msg;ub.style.display=msg?'block':'none';
}
function openCart(){document.getElementById('cpanel').classList.add('open');cartOpen=true}
function closeCart(){document.getElementById('cpanel').classList.remove('open');cartOpen=false}
function goChk(){closeCart();const c=document.getElementById('chk');c.style.display='block';c.scrollIntoView({behavior:'smooth'})}
function setEnt(v){ent=v;document.getElementById('rdel').className='ro'+(v==='delivery'?' sel':'');document.getElementById('rret').className='ro'+(v==='retirada'?' sel':'');document.getElementById('addrg').style.display=v==='delivery'?'block':'none'}
function setPay(v){pay=v;['pix','card','wa'].forEach(k=>document.getElementById('p'+k).className='po'+(k===(v==='cartao'?'card':v==='whatsapp'?'wa':v)?' sel':''));document.getElementById('pixbox').style.display=v==='pix'?'block':'none'}
function submitOrder(){
  const nome=document.getElementById('fnome').value.trim(),tel=document.getElementById('ftel').value.trim();
  if(!nome||!tel){alert('Preencha nome e telefone.');return}
  if(pay==='whatsapp'){sendWA();return}
  alert(`✅ Pedido confirmado, ${nome}!\nPagamento: ${pay.toUpperCase()}\nDúvidas: (21) 2577-7780`);
}
function sendWA(){
  if(!cart.length){window.open('https://wa.me/5521980354365?text=Olá! Gostaria de fazer um pedido.','_blank');return}
  const total=cart.reduce((s,i)=>s+i.price,0);
  let msg='Olá, OURO da Vila! 🍕\n\n';
  cart.forEach(i=>{msg+=`• ${i.name} — ${fmt(i.price)}\n`});
  msg+=`\n💰 Total: ${fmt(total)}\nEntrega: ${ent}`;
  window.open('https://wa.me/5521980354365?text='+encodeURIComponent(msg),'_blank');
}

